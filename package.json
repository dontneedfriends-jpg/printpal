{
  "name": "printpal",
  "version": "1.0.0",
  "description": "Filament tracker and 3D print cost calculator",
  "author": "PrintPAL",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.printpal.app",
    "productName": "PrintPAL",
    "directories": {
      "output": "dist5"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "error.html",
      "electron-app/**/*"
    ],
    "extraResources": [
      {
        "from": "electron-app/filament-calculator",
        "to": "filament-calculator",
        "filter": ["**/*"]
      },
      {
        "from": "electron-app/python",
        "to": "python",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": null
    }
  }
}
